import os
from fastapi import FastAPI
from dotenv import load_dotenv

# Load our local environment variables
load_dotenv()

app = FastAPI(title="Base Payment Project")

@app.get("/")
def read_root():
    return {"message": "System is initialized. Waiting for Architect Agent to add Stripe integration."}

@app.get("/config-check")
def check_env():
    # Check if the agent created a .env or if we have keys
    stripe_key = os.getenv("STRIPE_API_KEY", "NOT_FOUND")
    return {"stripe_status": "Ready" if stripe_key != "NOT_FOUND" else "Missing API Key"}
